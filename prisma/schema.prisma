model ReimbursementCase {
  id                       String                  @id @default(cuid())
  organizationId           String
  clinicId                 String
  buyAndBillCaseId         String?
  priorAuthorizationCaseId String?
  patientReferenceId       String?
  payerName                String
  expectedAmount           Decimal                 @db.Decimal(12, 2)
  expectedAllowedAmount    Decimal?                @db.Decimal(12, 2)
  underpaymentFlag         Boolean                 @default(false)
  status                   ReimbursementCaseStatus @default(EXPECTED)
  createdByUserId          String
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt

  organization               Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clinic                     Clinic                      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  buyAndBillCase             BuyAndBillCase?             @relation(fields: [buyAndBillCaseId], references: [id], onDelete: SetNull)
  priorAuthorizationCase     PriorAuthorizationCase?     @relation(fields: [priorAuthorizationCaseId], references: [id], onDelete: SetNull)
  createdBy                  User                        @relation("ReimbursementCaseCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  claims                     ClaimRecord[]
  payments                   PaymentRecord[]
  statusEvents               ReimbursementStatusEvent[]
  remittancePaymentsMatched  RemittancePayment[]         @relation("RemittancePaymentMatchedReimbursementCase")
  revenueOptimizationSignals RevenueOptimizationSignal[]

  @@index([organizationId])
  @@index([clinicId])
  @@index([status])
  @@index([underpaymentFlag])
  @@index([payerName])
  @@index([buyAndBillCaseId])
  @@index([priorAuthorizationCaseId])
  @@index([createdByUserId])
  @@index([createdAt])
}

model ClaimRecord {
