  matchedReimbursementCase ReimbursementCase? @relation("RemittancePaymentMatchedReimbursementCase", fields: [matchedReimbursementCaseId], references: [id], onDelete: SetNull)
  paymentRecord            PaymentRecord?     @relation(fields: [paymentRecordId], references: [id], onDelete: SetNull)

  @@index([remittanceFileId])
  @@index([claimReference])
  @@index([payerClaimControlNumber])
  @@index([reconciliationStatus])
  @@index([matchedClaimRecordId])
  @@index([matchedReimbursementCaseId])
  @@index([paymentRecordId])
  @@index([createdAt])
}

