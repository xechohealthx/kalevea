  renderingNpi               String?
  billingTaxId               String?
  reconciliationStatus       ReconciliationStatus @default(UNMATCHED)
  matchedClaimRecordId       String?
  matchedReimbursementCaseId String?
  paymentRecordId            String?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt

  remittanceFile           RemittanceFile     @relation(fields: [remittanceFileId], references: [id], onDelete: Cascade)
