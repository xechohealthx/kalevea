model RemittancePayment {
  id                         String               @id @default(cuid())
  remittanceFileId           String
  claimReference             String?
  payerClaimControlNumber    String?
  paidAmount                 Decimal              @db.Decimal(12, 2)
  adjustmentAmount           Decimal?             @db.Decimal(12, 2)
